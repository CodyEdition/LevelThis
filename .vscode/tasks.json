{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup (clone Vencord, copy plugin, install)",
      "type": "shell",
      "command": "npm run setup",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "npm run build",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Build (dev)",
      "type": "shell",
      "command": "npm run build:dev",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "npm run clean",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
